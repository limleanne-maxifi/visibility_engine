# ─── AI plan generation ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Database (Supabase) ──────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── Email delivery (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=
# Verified sender address in your Resend domain
FROM_EMAIL=hello@maxifidigital.com
# Email address that receives internal notifications for each new submission
MAXIFI_NOTIFY_EMAIL=
# Contact email shown in error messages and footer (server-side)
MAXIFI_CONTACT_EMAIL=letsgetstarted@maxifidigital.com
# Contact email accessible in client components
NEXT_PUBLIC_CONTACT_EMAIL=letsgetstarted@maxifidigital.com

# ─── Admin / results page ─────────────────────────────────────────────────────
# Server-only — do NOT prefix with NEXT_PUBLIC_ or the value will leak into the browser bundle
ADMIN_KEY=

# ─── Booking integration ──────────────────────────────────────────────────────
CALENDLY_URL=https://calendly.com/maxifi-digital

# ─── Checkout / upgrade URLs (fall back to CALENDLY_URL if unset) ─────────────
# Point these at your Stripe/Lemon Squeezy checkout pages when ready
REPORT_CHECKOUT_URL=
MONITOR_CHECKOUT_URL=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Publishable key is safe to expose to the browser (used by Stripe.js)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Secret key — server-side only, never prefix with NEXT_PUBLIC_
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret — from `stripe listen` (local) or Stripe dashboard (prod)
STRIPE_WEBHOOK_SECRET=whsec_...
# Report unlock price in the smallest currency unit (SGD cents). Default: 29900 = SGD 299.00
REPORT_PRICE_CENTS=29900

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used for magic-link emails, Stripe redirect URLs, and Origin validation
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Rate limiting (optional — in-process Map used if unset) ─────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Supabase service role (v2) ───────────────────────────────────────────────
# Service role key bypasses RLS — server-side only, never expose to browser
SUPABASE_SERVICE_KEY=
