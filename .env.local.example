# Copy to .env.local and fill in values for local dev.
# All keys here are server-side only unless prefixed NEXT_PUBLIC_.

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Server-only. Never prefix with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL — server-only (keep the service key co-located, never expose both).
SUPABASE_URL=
# Service role key — bypasses RLS and gives full DB access to API routes.
# The anon key is deliberately NOT used; all server-side access goes through
# the service key so RLS policies are the only access-control layer needed.
SUPABASE_SERVICE_KEY=

# ─── Resend ───────────────────────────────────────────────────────────────────
# Server-only.
RESEND_API_KEY=
# Verified sender address in your Resend domain.
FROM_EMAIL=hello@maxifidigital.com

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Server-only. Use sk_test_... locally, sk_live_... in production.
STRIPE_SECRET_KEY=
# Server-only. whsec_... from `stripe listen` (local) or Stripe dashboard (prod).
STRIPE_WEBHOOK_SECRET=
# Safe for browser — required by Stripe.js. pk_test_... or pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Report unlock price in the smallest currency unit (cents). e.g. 29900 = SGD 299
REPORT_PRICE_CENTS=29900

# ─── App URL ──────────────────────────────────────────────────────────────────
# Used in share links, email magic-link URLs, and Origin validation.
# Must not have a trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Product URLs ─────────────────────────────────────────────────────────────
# Stripe payment link or Calendly fallback for the full report upgrade CTA.
REPORT_CHECKOUT_URL=
# Monthly tracking product checkout URL.
MONITOR_CHECKOUT_URL=
# Strategy call booking — used in email templates and the results page.
CALENDLY_URL=https://calendly.com/maxifi-digital

# ─── Email addresses ──────────────────────────────────────────────────────────
# Internal new-lead notification recipient.
MAXIFI_NOTIFY_EMAIL=
# Shown in report footer for unsubscribe / contact links (server-side).
MAXIFI_CONTACT_EMAIL=letsgetstarted@maxifidigital.com
# Same address, accessible in client components.
NEXT_PUBLIC_CONTACT_EMAIL=letsgetstarted@maxifidigital.com

# ─── Security ─────────────────────────────────────────────────────────────────
# Guards /api/admin/leads. Minimum 32 random bytes. Server-only — never NEXT_PUBLIC_.
ADMIN_KEY=

# ─── Rate limiting (optional — in-process Map used if unset) ─────────────────
# Server-only. Required only if Upstash Redis edge rate limiting is enabled.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
